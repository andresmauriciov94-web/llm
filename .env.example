# =====================================================================
# Configuracion del sistema RAG. Copia este archivo a `.env` y ajusta.
#   cp .env.example .env
# =====================================================================

# ---- LLM -------------------------------------------------------------
# Proveedor: "ollama" (local, gratis, por defecto) u "openai" (API).
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:0.5b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512
OLLAMA_BASE_URL=http://ollama:11434
# Solo si LLM_PROVIDER=openai:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Embeddings (multilingue por defecto: contenido en espanol) ------
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ---- Vector store (Qdrant) ------------------------------------------
QDRANT_URL=http://qdrant:6333
COLLECTION_NAME=bank_web

# ---- Chunking --------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ---- Recuperacion ----------------------------------------------------
TOP_K=5
RERANK_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANK_TOP_N=3

# ---- Conversacion ----------------------------------------------------
# N: cantidad de mensajes previos que se mantienen en contexto.
CONVERSATION_WINDOW=6

# ---- Scraper ---------------------------------------------------------
SCRAPE_BASE_URL=https://www.bancolombia.com/
SCRAPE_MAX_PAGES=10
SCRAPE_DELAY_SECONDS=1.0
SCRAPE_RESPECT_ROBOTS=true

# ---- Almacenamiento --------------------------------------------------
DB_PATH=data/app.db
RAW_DIR=data/raw
CLEAN_DIR=data/clean

# ---- API / UI --------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://api:8000
